rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /app/config {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /screens/{screenId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /mediaItems/{mediaId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
